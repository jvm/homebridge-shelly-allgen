{
  "name": "homebridge-shelly-allgen",
  "displayName": "Homebridge Shelly AllGen",
  "version": "0.2.0",
  "description": "Homebridge dynamic platform plugin for Shelly Gen1 and Gen2+ devices.",
  "author": "Jose Mocito",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shelly-allgen-probe": "dist/cli/probe.js"
  },
  "files": [
    "dist",
    "config.schema.json",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvm/homebridge-shelly-allgen.git"
  },
  "bugs": {
    "url": "https://github.com/jvm/homebridge-shelly-allgen/issues"
  },
  "homepage": "https://github.com/jvm/homebridge-shelly-allgen#readme",
  "engines": {
    "node": ">=22",
    "homebridge": ">=2.0.0"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "shelly"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli/probe.js",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "probe": "tsx src/cli/probe.ts",
    "pack:local": "npm pack",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "homebridge-lib": "^8.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.26.0",
    "homebridge": "^2.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
